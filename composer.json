{
  "name": "jord-jd/web-article-formatter",
  "description": "Web Article Formatter",
  "type": "library",
  "license": "LGPL-3.0-only",
  "authors": [
    {
      "name": "Jordan Hall",
      "email": "jordan@hall05.co.uk"
    }
  ],
  "require": {
    "php": ">=5.5",
    "ext-dom": "*",
    "guzzlehttp/guzzle": "^6.5.8||^7.4.5",
    "dompdf/dompdf": "^0.8.2||^2.0.8||^3.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^4.8||^9.6"
  },
  "autoload": {
    "psr-4": {
      "JordJD\\WebArticleFormatter\\": "./src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "JordJD\\WebArticleFormatter\\Tests\\": "tests/"
    }
  },
  "replace": {
    "divineomega/web-article-formatter": "self.version"
  },
  "extra": {
    "branch-alias": {
      "dev-master": "3.0-dev"
    }
  }
}
